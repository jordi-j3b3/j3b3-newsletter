# Plantilla de variables de entorno. Copiar a config/.env y rellenar.
# config/.env NO se sube al repositorio (cubierto por .gitignore).

# --- API Anthropic (Sonnet 4.6 para borradores del piloto) ---
# Obtener en console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=

# --- API MailerLite (administrador, no la del form integrado) ---
# Generar en: MailerLite → Integrations → Developer API → Generate new token
# Permisos requeridos: lectura + escritura de campaigns y subscribers
MAILERLITE_API_TOKEN=

# IDs de los grupos MailerLite (crear manualmente en el panel)
MAILERLITE_GROUP_PREVIEW_ID=
MAILERLITE_GROUP_PILOT_ID=
# Futuros, no requeridos para el piloto:
# MAILERLITE_GROUP_GRATUITA_ID=
# MAILERLITE_GROUP_PREMIUM_ID=

# Remitente de los emails. El correo DEBE estar verificado en MailerLite
# (Settings → Sender domains / Sender emails).
MAILERLITE_FROM_EMAIL=
MAILERLITE_FROM_NAME=Observatorio del Comercio

# Dirección que recibe las preview. Debe coincidir con el único miembro
# del grupo MAILERLITE_GROUP_PREVIEW_ID.
EMAIL_PREVIEW=

# --- Repositorio del Observatorio (fuente local de datos) ---
OBSERVATORI_PATH=/Users/j3b3/Desktop/ESTUDI PIB/observatori-comerc

# --- Modo de ejecución ---
# prueba | produccion — se registra en send_log.json para auditoría
MODO_EJECUCION=prueba
